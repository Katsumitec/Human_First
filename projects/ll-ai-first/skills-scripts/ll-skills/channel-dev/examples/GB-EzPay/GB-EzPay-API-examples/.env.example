# GB-EzPay API 配置文件範本
# 複製此文件為 .env 並填入實際值

# API 基礎地址（不含尾部斜杠）
BASE_URL=https://your-api-domain.com

# 商戶編號（平台分配）
CUSTOMER_ID=50003

# API 密鑰（平台提供）
API_KEY=a4f3d1b62c31e6905059a09b6bb8102047c7a604e6cb1a8a3d8837ed1986854b

# 代收通道編號（請向客服索取）
PAY_CHANNEL_ID=1

# 回調地址
NOTIFY_URL=https://your-domain.com/api/callback
