# GoldenPay 泰國 對接範例環境變數
# 使用方式：複製為 .env（本目錄下），填入實際值。.env 不可 commit（包含敏感資訊）

# 接口域名與路徑
BASE_URL=https://ds-api.goldenpaythai.com
URL_DEPOSIT=/api/v1/mch/pmt-orders
URL_DEPOSIT_QUERY=/api/v1/mch/pmt-orders
URL_WITHDRAW=/api/v1/mch/wdl-orders
URL_WITHDRAW_QUERY=/api/v1/mch/wdl-orders
URL_BALANCE=/api/v1/mch/balance

# 商戶
MCH_ID=4133
API_TOKEN=見_email_待補

# 預設值
CURRENCY=THB
CHANNEL=bank
CALLBACK_URL=https://your-domain.example.com/api/callback/gj
RETURN_URL=https://your-domain.example.com/pay/return
