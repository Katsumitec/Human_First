# GG-NewSKYpay API 範例配置（範本，請複製為 .env 後填入真實值）

# 上游 API 基礎 URL（HTTP；不要強制 HTTPS）
BASE_URL=http://api.newsky.vip

# 商戶資訊
MERCHANT_ID=30038
MERCHANT_KEY=__REPLACE_WITH_REAL_KEY__

# 接口路徑（一般無需修改，沿用上游文檔規範）
DEPOSIT_CT_PATH=/hpay/dt/vnd/ct
DEPOSIT_QUERY_PATH=/hpay/dt/vnd/query
WITHDRAW_CT_PATH=/hpay/wd/vnd/ct
WITHDRAW_QUERY_PATH=/hpay/wd/vnd/query
BALANCE_PATH=/hpay/merchant/balance

# 我方對外通知地址（提供給上游）
NOTIFY_URL=http://your-server.example.com/callback/gg/notify

# 我方對外反查地址（提供給上游 — 上游主動回調我方反查）
QUERY_MERCHANT_ORDER_URL=http://your-server.example.com/callback/gg/query_merchant_order

# 範例執行用：固定 payType
PAY_TYPE=1060

# 反查接口的 Flask 服務監聽 port
CALLBACK_SERVER_HOST=0.0.0.0
CALLBACK_SERVER_PORT=5000

# 測試用商戶訂單（執行範例時可帶入）
TEST_MERCHANT_ORDER_ID=GG_TEST_20260427_0001
TEST_PAY_AMOUNT=10000
TEST_USER_ID=78
TEST_USER_IP=127.0.0.1

# 代付測試
TEST_BANK_TYPE=ACB
TEST_BANK_NUM=36954697135656
TEST_BANK_ACCOUNT=NGUYEN VAN A
